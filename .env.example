# ── Kafka / Redpanda ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=sensor_readings
KAFKA_GROUP_ID=trace_consumer

# ── TimescaleDB ──────────────────────────────────────────────────────────────
TSDB_DSN=postgresql://trace:trace@localhost:5432/trace

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Sensor generator ─────────────────────────────────────────────────────────
READINGS_PER_SECOND=10        # across all 10 machines (1 reading/machine/sec)
ANOMALY_RATE=0.03             # 3 % of readings injected as anomalies
RANDOM_SEED=42                # reproducibility

# ── Detector ─────────────────────────────────────────────────────────────────
WINDOW_SIZE=60
ZSCORE_THRESHOLD=2.5
WARMUP_READINGS=10            # readings required before detector fires

# ── Pipeline control ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
